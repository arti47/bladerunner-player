# firebase-config.js IS committed for this project (owner opted to ship real keys
# so multiplayer works on the live site). Firebase web API keys are not classic
# secrets — access is governed by database.rules.json + auth. Keep those rules
# locked down. If you fork this and don't want keys public, replace them and set
# FIREBASE_ENABLED = false.

